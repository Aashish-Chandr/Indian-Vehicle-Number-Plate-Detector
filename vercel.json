{
  "buildCommand": "bash build.sh",
  "functions": {
    "api/index.py": {
      "runtime": "python3.11",
      "maxDuration": 300,
      "memory": 3008
    }
  },
  "env": {
    "FLASK_ENV": "production",
    "PYTHONUNBUFFERED": "1",
    "SESSION_SECRET": "secure-production-key-set-in-vercel-dashboard"
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index.py"
    }
  ]
}
