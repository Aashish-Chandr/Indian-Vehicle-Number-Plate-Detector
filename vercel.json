{
  "buildCommand": "pip install -r requirements.txt",
  "framework": "python",
  "runtime": "python3.11",
  "functions": {
    "api/index.py": {
      "runtime": "python3.11",
      "maxDuration": 300,
      "memory": 3008
    }
  },
  "env": {
    "FLASK_ENV": "production",
    "PYTHONUNBUFFERED": "1"
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index.py"
    }
  ]
}
